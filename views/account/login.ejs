<% if (title) { %>
<h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>

<div class="form-div">
    <form id="login-form">
        <fieldset>
            <label for="account_email">Email:<input type="email" name="account_email" id="account_email"></label>
            <label for="account_password">Password:<input type="password" name="account_password" id="account_password"></label>
            <button type="submit" id="login-button">LOGIN</button>
        </fieldset>
        <p>No account? <a href="/account/registration">Sign-up</a></p>
    </form>
</div>