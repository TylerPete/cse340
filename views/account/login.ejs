<% if (title) { %>
<h1><%= title %></h1>
<% } else {
    res.redirect('/')
} %>


// Form HTML
<form>
    <label for="account_email">Email:<input type="text" name="account_email" id="account_email"></label>
    <label for="account_password">Password:<input type="text" name="account_password" id="account_password"></label>
    <button type="submit">LOGIN</button>

    <p>No account? <a href="/account/registration">Sign-up</a></p>
</form>