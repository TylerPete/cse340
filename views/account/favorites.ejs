<h1><%= title %></h1>

<% if (favorites.length > 0) { %>
    <ul>
        <% favorites.forEach(vehicle => { %>
            <li><a href="/inv/detail/<%= vehicle.inv_id %>"><%= vehicle.inv_make %> <%= vehicle.inv_model %></a></li>
        <% }) %>
    </ul>
<% } else { %>
    <p>No favorites found.</p>
<% } %>